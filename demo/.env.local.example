# Motor de IA do bot — PROVIDER-AGNÓSTICO. Escolha UM provedor hospedado.
# Recomendado: OpenRouter (um gateway só p/ os melhores modelos; troca por env).
# Copie este arquivo para .env.local e preencha. Sem isso, o chat mostra um aviso (não quebra).

LLM_PROVIDER=openrouter
# Slug do modelo (exemplos no OpenRouter):
#   google/gemini-2.5-flash     -> rápido e barato; ótimo custo p/ clínica
#   anthropic/claude-sonnet-4.5     -> mais forte p/ "nunca inventa / nunca diagnostica"
#   openai/gpt-4o-mini              -> barato
LLM_MODEL=google/gemini-2.5-flash
LLM_API_KEY=sk-or-...

# --- Outros provedores (descomente e ajuste) ---
# LLM_PROVIDER=groq       LLM_MODEL=llama-3.3-70b-versatile   LLM_API_KEY=gsk_...
# LLM_PROVIDER=openai     LLM_MODEL=gpt-4o-mini               LLM_API_KEY=sk-...
# LLM_PROVIDER=gemini     LLM_MODEL=gemini-2.5-flash          LLM_API_KEY=AIza...
# LLM_PROVIDER=anthropic  LLM_MODEL=claude-sonnet-4-6         ANTHROPIC_API_KEY=sk-ant-...
# LLM_PROVIDER=ollama     LLM_MODEL=qwen2.5:7b               (local, sem key)

# Se o modelo rejeitar o "JSON mode", desligue:
# LLM_JSON_MODE=off
